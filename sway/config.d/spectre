### Output configuration
#
# Default wallpaper (more resolutions are available in /usr/share/backgrounds/sway/)
#
# Example configuration:
#
#   output HDMI-A-1 resolution 1920x1080 position 1920,0
#
# You can get the names of your outputs by running: swaymsg -t get_outputs

output eDP-1 enable scale 1.5 position 0,0 mode 2880x1800@120.001Hz
output * bg ~/.config/sway/bg/mountains.jpg fill

### Lid handling: blank the internal display only, never suspend.
### Suspend/resume hangs on this laptop's Alpine kernel (missing Meteor Lake
### platform support that Void's mainline kernel has), so elogind is set to
### HandleLidSwitch=ignore and the lid just powers eDP-1 off/on here.
bindswitch --locked lid:on  output eDP-1 power off
bindswitch --locked lid:off output eDP-1 power on

### Idle configuration disabled on spectre

### Input configuration
#
# Example configuration:
#
#   input "2:14:SynPS/2_Synaptics_TouchPad" {
#       dwt enabled
#       tap enabled
#       natural_scroll enabled
#       middle_emulation enabled
#   }
#
# You can get the names of your inputs by running: swaymsg -t get_inputs
# Read `man 5 sway-input` for more information about this section.

input type:keyboard {
    xkb_layout eu,us
    xkb_model "pc105"
}

input type:touchpad {
    tap enabled
    natural_scroll enabled
    scroll_factor 2
}

input 1267:16937:ELAN2513:00_04F3:4229_Stylus map_to_output eDP-1

bindsym XF86MonBrightnessUp exec brillo -A 2 && (echo "$(brillo -G) / 1" | bc > $WOBSOCK)
bindsym XF86MonBrightnessDown exec brillo -U 2 && (echo "$(brillo -G) / 1" | bc > $WOBSOCK)


# Run kanshi to configure external displays automatically
exec_always kill -1 $(pidof kanshi)
exec ~/.config/kanshi/run.sh
