#!/bin/sh
# Manual recovery for the Arc B580 dual-DP joiner bug: after a DPMS off/on one screen can stay dark
# because DP-2 (6K) needs a joiner pipe pair and hides its secondary pipe from wlroots. Re-enable from a
# clean slate with single-pipe DP-1 first (claims pipe A), then DP-2, powering each on after enable.
# The modeset is non-deterministic, so verify and retry until both are active and powered.

both_on() {
	swaymsg -t get_outputs -r | python3 -c '
import sys, json
o = {d["name"]: d for d in json.load(sys.stdin)}
ok = all(o.get(n, {}).get("active") and o.get(n, {}).get("power") for n in ("DP-1", "DP-2"))
sys.exit(0 if ok else 1)
'
}

attempt() {
	swaymsg 'output DP-2 disable'; sleep 1
	swaymsg 'output DP-1 disable'; sleep 1
	swaymsg 'output DP-1 enable'; sleep 1
	swaymsg 'output DP-1 power on'; sleep 1
	swaymsg 'output DP-2 enable'; sleep 1
	swaymsg 'output DP-2 power on'; sleep 1
}

i=1
while [ "$i" -le 5 ]; do
	attempt
	if both_on; then
		echo "recovered both displays (attempt $i)"
		exit 0
	fi
	echo "attempt $i did not recover both, retrying..."
	i=$((i + 1))
done

echo "failed to recover both displays after 5 attempts, restart sway to reset"
exit 1
